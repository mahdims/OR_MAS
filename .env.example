# LLM Provider Configuration
# Choose one of: openai, gemini, deepseek, qwen, local
PROVIDER=openai

# Model name (depends on provider)
# OpenAI: gpt-4.1, gpt-4o, o4-mini
# Gemini: gemini-2.5-pro, gemini-2.5-flash
# DeepSeek: deepseek-chat, deepseek-coder
MODEL_NAME=openrouter/openai/gpt-5.2

# Optional per-task override when code generation should use a stronger model.
# CODE_MODEL_NAME=gpt-4.1

# API Key (required for cloud providers)
API_KEY=your-api-key-here

# Base URL (required for OpenAI-compatible providers like DeepSeek, Qwen, or local)
# BASE_URL=https://api.deepseek.com/v1
# BASE_URL=http://localhost:8000/v1

# Optional solver override.
# If not set, OR_MAS tries: scip, then highs.
# SOLVER=scip
