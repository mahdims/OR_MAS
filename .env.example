# OR_MAS reads the repo root `.env`.
# This file mirrors the shared settings for convenience.

MODEL_NAME=
DEFAULT_MODEL=openrouter/openai/gpt-5.2

# Optional per-task overrides.
# STRUCTURED_MODEL_NAME=
# CODE_MODEL_NAME=
# PROVIDER=litellm

API_KEY=
# BASE_URL=

OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_BASE_URL=

OPENROUTER_API_KEY=
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=
# OPENROUTER_PROVIDER_SORT=throughput
# OPENROUTER_PROVIDER_ORDER=groq,fireworks
# OPENROUTER_PROVIDER_ONLY=groq
# OPENROUTER_PROVIDER_IGNORE=deepinfra
# OPENROUTER_PROVIDER_ALLOW_FALLBACKS=true
# OPENROUTER_PROVIDER_REQUIRE_PARAMETERS=true

GEMINI_API_KEY=

# Optional solver override.
# If not set, OR_MAS tries: scip, then highs.
# SOLVER=scip
